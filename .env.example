# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only. NEVER expose to the client. Used by admin API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Seed reference for the admin allowlist. The AUTHORITATIVE source is the
# admin_emails table (supabase/seed.sql); RLS and the app both read that table.
# This value is not consulted for authorization at runtime — keep it in sync with
# the table when seeding.
ADMIN_EMAILS=prajjit2009@gmail.com
